{
  "info": {
    "name": "NexKart API Collection",
    "description": "Complete REST API collection for NexKart E-Commerce Application",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080/api", "type": "string" },
    { "key": "token", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "🔐 Authentication",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register",
            "body": { "mode": "raw", "raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\",\n  \"phone\": \"9876543210\"\n}" }
          }
        },
        {
          "name": "Login",
          "event": [{ "listen": "test", "script": { "exec": ["const res = pm.response.json();", "pm.collectionVariables.set('token', res.token);", "console.log('Token saved:', res.token);"] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\"\n}" }
          }
        },
        {
          "name": "Login as Admin",
          "event": [{ "listen": "test", "script": { "exec": ["const res = pm.response.json();", "pm.collectionVariables.set('token', res.token);"] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@nexkart.com\",\n  \"password\": \"password\"\n}" }
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/auth/me"
          }
        }
      ]
    },
    {
      "name": "📦 Products",
      "item": [
        {
          "name": "Get All Products",
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/products?page=0&size=12&sortBy=createdAt&sortDir=desc", "query": [{ "key": "page", "value": "0" }, { "key": "size", "value": "12" }, { "key": "sortBy", "value": "createdAt" }, { "key": "sortDir", "value": "desc" }] } }
        },
        {
          "name": "Search Products",
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/products?keyword=phone&categoryId=1&minPrice=1000&maxPrice=50000&page=0&size=10", "query": [{ "key": "keyword", "value": "phone" }, { "key": "categoryId", "value": "1" }, { "key": "minPrice", "value": "1000" }, { "key": "maxPrice", "value": "50000" }] } }
        },
        {
          "name": "Get Product by ID",
          "request": { "method": "GET", "url": "{{baseUrl}}/products/1" }
        },
        {
          "name": "Get Featured Products",
          "request": { "method": "GET", "url": "{{baseUrl}}/products/featured" }
        },
        {
          "name": "Get Related Products",
          "request": { "method": "GET", "url": "{{baseUrl}}/products/1/related" }
        },
        {
          "name": "Create Product (Admin)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/products",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Test Product\",\n  \"description\": \"A great product for testing\",\n  \"price\": 1999.00,\n  \"discountPrice\": 1499.00,\n  \"stock\": 100,\n  \"imageUrl\": \"https://via.placeholder.com/300\",\n  \"brand\": \"TestBrand\",\n  \"categoryId\": 1,\n  \"featured\": true\n}" }
          }
        },
        {
          "name": "Update Product (Admin)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/products/1",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Updated Product Name\",\n  \"price\": 2499.00,\n  \"stock\": 50,\n  \"categoryId\": 1\n}" }
          }
        },
        {
          "name": "Delete Product (Admin)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/products/1"
          }
        }
      ]
    },
    {
      "name": "🗂️ Categories",
      "item": [
        { "name": "Get All Categories", "request": { "method": "GET", "url": "{{baseUrl}}/categories" } },
        { "name": "Get Category by ID", "request": { "method": "GET", "url": "{{baseUrl}}/categories/1" } },
        {
          "name": "Create Category (Admin)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/categories",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Automotive\",\n  \"description\": \"Car accessories and auto parts\"\n}" }
          }
        }
      ]
    },
    {
      "name": "🛒 Cart",
      "item": [
        { "name": "Get Cart", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": "{{baseUrl}}/cart" } },
        {
          "name": "Add to Cart",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/cart/add",
            "body": { "mode": "raw", "raw": "{\n  \"productId\": 1,\n  \"quantity\": 2\n}" }
          }
        },
        {
          "name": "Update Cart Item",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/cart/update",
            "body": { "mode": "raw", "raw": "{\n  \"cartItemId\": 1,\n  \"quantity\": 3\n}" }
          }
        },
        { "name": "Remove Cart Item", "request": { "method": "DELETE", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": "{{baseUrl}}/cart/remove/1" } },
        { "name": "Clear Cart", "request": { "method": "DELETE", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": "{{baseUrl}}/cart/clear" } }
      ]
    },
    {
      "name": "📋 Orders",
      "item": [
        {
          "name": "Place Order",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/orders/place",
            "body": { "mode": "raw", "raw": "{\n  \"addressId\": 1,\n  \"paymentMethod\": \"COD\",\n  \"notes\": \"Please deliver between 9am-6pm\"\n}" }
          }
        },
        { "name": "Get My Orders", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": "{{baseUrl}}/orders?page=0&size=10" } },
        { "name": "Get Order by ID", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": "{{baseUrl}}/orders/1" } },
        { "name": "Cancel Order", "request": { "method": "POST", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": "{{baseUrl}}/orders/1/cancel" } },
        { "name": "Get All Orders (Admin)", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": "{{baseUrl}}/orders/admin/all?page=0&size=10" } },
        {
          "name": "Update Order Status (Admin)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/orders/admin/1/status",
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"SHIPPED\"\n}" }
          }
        }
      ]
    },
    {
      "name": "⭐ Reviews",
      "item": [
        { "name": "Get Product Reviews", "request": { "method": "GET", "url": "{{baseUrl}}/reviews/product/1?page=0&size=5" } },
        {
          "name": "Add Review",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/reviews/product/1",
            "body": { "mode": "raw", "raw": "{\n  \"rating\": 5,\n  \"title\": \"Excellent product!\",\n  \"comment\": \"Very happy with this purchase. Great build quality and fast delivery.\"\n}" }
          }
        },
        { "name": "Delete Review", "request": { "method": "DELETE", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": "{{baseUrl}}/reviews/1" } }
      ]
    },
    {
      "name": "👤 Users",
      "item": [
        { "name": "Get Profile", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": "{{baseUrl}}/users/profile" } },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/users/profile",
            "body": { "mode": "raw", "raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Updated\",\n  \"phone\": \"9876543210\"\n}" }
          }
        },
        { "name": "Get Addresses", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": "{{baseUrl}}/users/addresses" } },
        {
          "name": "Add Address",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/users/addresses",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"John Doe\",\n  \"phone\": \"9876543210\",\n  \"addressLine1\": \"123 MG Road\",\n  \"addressLine2\": \"Near City Mall\",\n  \"city\": \"Bangalore\",\n  \"state\": \"Karnataka\",\n  \"pincode\": \"560001\",\n  \"country\": \"India\",\n  \"type\": \"HOME\"\n}" }
          }
        }
      ]
    }
  ]
}
